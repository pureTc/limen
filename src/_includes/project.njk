---
layout: base.njk
---
<div class="project-detail" style="padding: 40px; max-width: 800px;">
  <a href="/" style="text-decoration: none; color: #999; font-size: 13px; font-family: monospace;">➔ BACK</a>
  
  <header style="margin-top: 40px; border-bottom: 1px solid #eee; padding-bottom: 20px; font-family: monospace;">
    <h1 style="font-size: 20px; font-weight: 500;">{{ id }} – {{ title }}</h1>
    <p style="color: #666; font-size: 12px; margin-top: 5px;">{{ doc }}</p>
  </header>

  <div style="margin-top: 30px; line-height: 1.8; color: #333;">
    {{ content | safe }}
  </div>
</div>